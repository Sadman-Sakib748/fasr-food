{
  "name": "fastfeast-backend",
  "version": "1.0.0",
  "description": "FastFeast Food Delivery API - Complete Production Backend",
  "main": "dist/server.js",
 "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/server.js",
    "vercel-build": "npm run build",
    "clean": "rm -rf dist",
    "build:clean": "npm run clean && npm run build",
    "seed": "ts-node src/seeders/run.ts",
    "seed:dev": "NODE_ENV=development ts-node src/seeders/run.ts",
    "seed:prod": "NODE_ENV=production ts-node src/seeders/run.ts",
    "seed:admin": "ts-node src/seeders/run.ts --admin-only",
    "seed:clear": "ts-node src/seeders/clear.ts",
    "seed:reset": "npm run seed:clear && npm run seed",
    "type-check": "tsc --noEmit",
    "debug-login": "ts-node debug-login.ts",
    "fix-password": "ts-node fix-password.ts"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.3.2",
    "helmet": "^7.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.5",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "redis": "^4.6.10",
    "socket.io": "^4.7.2",
    "stripe": "^14.16.0",
    "uuid": "^9.0.1",
    "winston": "^3.10.0",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/express-serve-static-core": "^4.17.36",
    "@types/hpp": "^0.2.4",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.19.43",
    "@types/nodemailer": "^6.4.9",
    "@types/passport": "^1.0.17",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/stripe": "^8.0.417",
    "@types/uuid": "^9.0.3",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
